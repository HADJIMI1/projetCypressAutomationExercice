    "cypress": "^15.11.0",
    "cypress-xpath": "^2.0.1",
    "esbuild": "^0.27.4",
    "mocha": "^11.7.5",
    "mochawesome": "^7.1.4",
    "mochawesome-merge": "^5.1.1",
    "mochawesome-report-generator": "^6.3.2"
  }
